# в”Җв”Җ PostgreSQL (docker composeмқҳ db м»Ён…Ңмқҙл„Ҳ) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=orchestrator

# в”Җв”Җ API м„Өм • (ORCH_ м ‘л‘җ нҷҳкІҪліҖмҲҳ) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
ORCH_ENV=local
ORCH_LOG_LEVEL=INFO
ORCH_LOG_JSON=true

# composeмқҳ db м»Ён…Ңмқҙл„ҲлҠ” нҳёмҠӨнҠём—җ 15432лЎң л…ём¶ңлҗңлӢӨ (POSTGRES_HOST_PORTлЎң ліҖкІҪ к°ҖлҠҘ).
# м•„лһҳ URLмқҖ лҸ„м»Ө л°–(нҳёмҠӨнҠё)м—җм„ң APIлҘј м§Ғм ‘ мӢӨн–үн•  л•Ңл§Ң мӮ¬мҡ©лҗңлӢӨ.
POSTGRES_HOST_PORT=15432
ORCH_DATABASE_URL=postgresql+asyncpg://orchestrator:change-me-strong-password@localhost:15432/orchestrator

ORCH_SESSION_TTL_HOURS=168
# HTTPS мҡҙмҳҒ нҷҳкІҪм—җм„ңлҠ” true
ORCH_SESSION_COOKIE_SECURE=false

# в”Җв”Җ мөңмҙҲ кҙҖлҰ¬мһҗ кі„м • (мІ« кё°лҸҷ мӢң мһҗлҸҷ мғқм„ұ, мқҙлҜё мһҲмңјл©ҙ кұҙл„ҲлңҖ) в”Җв”Җ
# л°ҳл“ңмӢң мһҗмӢ мқҳ к°’мңјлЎң л°”кҝҖ кІғ. мқҙ нҢҢмқј(.env.example)мқҳ к°’мқҖ мҳҲмӢңмқј лҝҗмқҙлӢӨ.
ORCH_ADMIN_EMAIL=admin@example.com
ORCH_ADMIN_PASSWORD=change-me-now
ORCH_ADMIN_DISPLAY_NAME=кҙҖлҰ¬мһҗ
